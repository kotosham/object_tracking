# VLM credentials for the Planner Orchestrator (Phase 4) -- TEMPLATE.
#
# Copy this file to `vlm.env`, fill in your real values, and source it into the
# shell BEFORE launching the orchestrator so the values become environment
# variables the node reads at runtime:
#
#     cp vlm.env.example vlm.env      # then edit vlm.env
#     set -a; source vlm.env; set +a  # export every assignment into the env
#     ros2 run planner_orchestrator orchestrator_node
#
# The real `vlm.env` is gitignored (only *.env.example is tracked) so the key
# never lands in git. A non-empty matching ROS param (vlm_base_url / vlm_api_key
# / vlm_model) still overrides the env value if you prefer to pass it explicitly.
# With a base_url present from either source the real OpenAI-compatible client
# engages automatically; pass use_mock:=true to force the offline mock instead.

# OpenAI-compatible base URL, INCLUDING the version path but NOT /chat/completions
# (the client appends that). Examples:
#   https://api.openai.com/v1
#   https://dashscope-intl.aliyuncs.com/compatible-mode/v1   (Qwen3-VL)
#   http://localhost:8000/v1                                  (local vLLM/Ollama)
VLM_BASE_URL=

# API key sent as `Authorization: Bearer <key>`.
VLM_API_KEY=

# Vision-capable model id, e.g. qwen2.5-vl-72b-instruct, gpt-4o, etc.
VLM_MODEL=
